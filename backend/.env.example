WASTE_APP_NAME=Waste Sorting YOLOv26 Backend
WASTE_APP_VERSION=0.1.0
WASTE_API_V1_PREFIX=/api/v1
WASTE_DEBUG=false
WASTE_CORS_ORIGINS=http://localhost:5173
WASTE_UPLOAD_MAX_BYTES=8388608
WASTE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# These paths line up with the Git LFS-tracked weights in the repo.
WASTE_YOLOV26_MODEL_NAME=yolo26n
WASTE_YOLOV26_WEIGHTS_PATH=runtime/weights/yolo26n.pt
WASTE_YOLOV26_CONFIDENCE_THRESHOLD=0.15
WASTE_YOLOV26_IOU_THRESHOLD=0.65
WASTE_YOLOV26_IMAGE_SIZE=1280
WASTE_YOLOV26_MAX_DETECTIONS=500
# Use "cpu" for widest compatibility. Change to "0" to use the first CUDA GPU.
WASTE_YOLOV26_DEVICE=cpu
WASTE_YOLOV26_PRELOAD_ON_STARTUP=false

WASTE_DETECTOR_MODEL_NAME=waste_yolo26s_taco
WASTE_DETECTOR_WEIGHTS_PATH=runs/waste_detector/waste_yolo26s_taco/weights/best.pt
WASTE_DETECTOR_CONFIDENCE_THRESHOLD=0.15
WASTE_DETECTOR_IOU_THRESHOLD=0.65
WASTE_DETECTOR_IMAGE_SIZE=640
WASTE_DETECTOR_MAX_DETECTIONS=500
# Use "cpu" for widest compatibility. Change to "0" to use the first CUDA GPU.
WASTE_DETECTOR_DEVICE=cpu
WASTE_DETECTOR_PRELOAD_ON_STARTUP=false

WASTE_HYBRID_PRIMARY_MIN_CONFIDENCE=0.45
WASTE_HYBRID_PRIMARY_MIN_MATCHES=1
# Organic is treated as a weak group because the custom model has very limited coverage for it.
WASTE_HYBRID_WEAK_GROUPS=organic
WASTE_HYBRID_GROUP_MIN_CONFIDENCE=recyclable=0.40,inorganic=0.22
WASTE_HYBRID_STRATEGY=merge
WASTE_DETECTOR_USE_TTA=false
